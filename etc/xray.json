{
    "log": {
        "loglevel": "warning"
    },
    "inbounds": [
        {
            "listen": "/etc/caddy/vmess",
            "protocol": "vmess",
            "settings": { "clients": [{"id": "$AUUID"}] },
            "streamSettings": { "network": "ws", "wsSettings": { "path": "/$AUUID-vmess" } }
        },
        {
            "listen": "/etc/caddy/vless",
            "protocol": "vless",
            "settings": { "clients": [{"id": "$AUUID"}], "decryption": "none" },
            "streamSettings": { "network": "ws", "wsSettings": { "path": "/$AUUID-vless" } }
        },
        {
            "listen": "/etc/caddy/trojan",
            "protocol": "trojan",
            "settings": { "clients": [{"password": "$AUUID"}] },
            "streamSettings": { "network": "ws", "wsSettings": { "path": "/$AUUID-trojan" } }
        },
        {
            "port": 4234,
            "listen": "127.0.0.1",
            "protocol": "shadowsocks",
            "settings": {
                "method": "$ParameterSSENCYPT",
                "password": "$AUUID"
            },
            "streamSettings": { "network": "ws", "wsSettings": { "path": "/$AUUID-ss" } }
        },
        {
            "port": 5234,
            "listen": "127.0.0.1",
            "protocol": "socks",
            "settings": {
                "auth": "password",
                "accounts": [{ "user": "$AUUID", "pass": "$AUUID" }]
            },
            "streamSettings": { "network": "ws", "wsSettings": { "path": "/$AUUID-socks" } }
        }
    ],
    "outbounds": [
        { "protocol": "freedom", "tag": "direct" },
        { "protocol": "blackhole", "tag": "blocked" },
        { 
            "protocol": "socks", 
            "tag": "tor", 
            "settings": { "servers": [{ "address": "127.0.0.1", "port": 9050 }] } 
        }
    ],
    "routing": {
        "rules": [
            { "type": "field", "outboundTag": "tor", "domain": ["geosite:tor"] },
            { "type": "field", "outboundTag": "blocked", "domain": ["geosite:category-ads-all"] }
        ]
    }
}
