:8080

root * /usr/share/caddy
file_server browse

header {
    X-Robots-Tag none
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
}

respond /health "OK" 200

# VLESS - 使用簡單 TCP 反代（推薦先用這個測試）
@websocket_xray_vless {
    header Connection *Upgrade*
    header Upgrade websocket
    path /vless
}
reverse_proxy @websocket_xray_vless localhost:8081

# 如果你還想保留原本的 UUID 路徑，可以把上面改成：
# path /$AUUID-vless
